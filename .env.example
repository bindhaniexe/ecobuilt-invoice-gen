# Authentication — the shared password to enter the app.
INVOICE_APP_PASSWORD=change-me

# Secret for signing session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Neon Postgres connection string for multi-device sync.
# Copy the pooled connection string from your Neon project dashboard.
# Leave unset to run fully offline (localStorage only).
DATABASE_URL=
